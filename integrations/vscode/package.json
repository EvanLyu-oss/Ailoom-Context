{
  "name": "ailoom-context-vscode",
  "displayName": "Ailoom Context",
  "description": "Local-first AI/IDE handoff for Ailoom Context skeletons, savings, and safety checks.",
  "version": "0.0.1",
  "publisher": "ailoom",
  "license": "MIT",
  "icon": "assets/ailoom-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/EvanLyu-oss/Ailoom-Context.git",
    "directory": "integrations/vscode"
  },
  "homepage": "https://github.com/EvanLyu-oss/Ailoom-Context",
  "bugs": {
    "url": "https://github.com/EvanLyu-oss/Ailoom-Context/issues"
  },
  "keywords": [
    "ai",
    "context",
    "local-first",
    "token-savings",
    "coding-agents",
    "handoff",
    "restore"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "galleryBanner": {
    "color": "#0B2D48",
    "theme": "dark"
  },
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onCommand:ailoom.handoffWorkspace",
    "onCommand:ailoom.showSavings",
    "onCommand:ailoom.openSkeleton",
    "onCommand:ailoom.openHandoffPrompt",
    "onCommand:ailoom.versionCheck",
    "onCommand:ailoom.doctor",
    "onCommand:ailoom.cleanPreview"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ailoom.handoffWorkspace",
        "title": "Ailoom: Handoff Current Workspace"
      },
      {
        "command": "ailoom.showSavings",
        "title": "Ailoom: Show Savings"
      },
      {
        "command": "ailoom.openSkeleton",
        "title": "Ailoom: Open Skeleton"
      },
      {
        "command": "ailoom.openHandoffPrompt",
        "title": "Ailoom: Open AI Handoff Prompt"
      },
      {
        "command": "ailoom.versionCheck",
        "title": "Ailoom: Version / Install Check"
      },
      {
        "command": "ailoom.doctor",
        "title": "Ailoom: Doctor"
      },
      {
        "command": "ailoom.cleanPreview",
        "title": "Ailoom: Clean Preview"
      }
    ],
    "configuration": {
      "title": "Ailoom Context",
      "properties": {
        "ailoom.commandPath": {
          "type": "string",
          "default": "ailoom",
          "description": "Path to the local ailoom command. Use an executable path, not shell syntax."
        },
        "ailoom.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Optional Python executable used for the python -m cli fallback when ailoom is not on PATH."
        },
        "ailoom.enablePythonModuleFallback": {
          "type": "boolean",
          "default": true,
          "description": "Try python -m cli fallbacks when the ailoom command is not found."
        }
      }
    }
  },
  "scripts": {
    "lint": "node --check extension.js",
    "package": "npx @vscode/vsce package --no-dependencies",
    "prepublish-check": "npm run lint && npm run package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0"
  }
}
